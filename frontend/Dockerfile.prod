# ========================================
# Stage 1 : build Nuxt 4
# ========================================
FROM node:22-slim AS builder

WORKDIR /app

# Installer les dépendances (via lockfile pour builds reproductibles)
COPY package.json package-lock.json* ./
RUN npm ci

# Copier le code source
COPY . .

# Variable d'environnement injectée au build (chemin relatif via Nginx)
ARG NUXT_PUBLIC_API_BASE=/api
ENV NUXT_PUBLIC_API_BASE=$NUXT_PUBLIC_API_BASE

# Build Nuxt (SSR) -> sortie dans .output/
RUN npm run build

# ========================================
# Stage 2 : runtime minimal
# ========================================
FROM node:22-slim AS runner

WORKDIR /app

# Copier uniquement la sortie de build
COPY --from=builder /app/.output ./.output

ENV NODE_ENV=production
ENV HOST=0.0.0.0
ENV PORT=3000
ENV NITRO_PORT=3000

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD node -e "fetch('http://localhost:3000/').then(r => process.exit(r.ok ? 0 : 1)).catch(() => process.exit(1))"

CMD ["node", ".output/server/index.mjs"]
