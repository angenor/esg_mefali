# Docker
*.pid


# BMAD Method - runtime caches (artefacts restent versionnés)
_bmad/.cache/
_bmad/*.log
_bmad-output/**/.cache/
_bmad-output/**/*.tmp

# E2E live (agent-browser) — captures de runs locaux (story 8.3+)
frontend/tests/e2e-live/screenshots/*
!frontend/tests/e2e-live/screenshots/.gitkeep

# Bench LLM providers (Story 10.13) — outputs JSON contiennent prompts + réponses
# + métriques coût/tokens, à ne jamais committer (risque fuite PII re-bench Phase 1).
bench-results*.json
bench-report-*.json
/tmp/bench-*.json

# Storybook build artefact (Story 10.15+) — généré par `npm run storybook:build`
# et uploadé en CI (workflow 10.14), jamais commité.
frontend/storybook-static/