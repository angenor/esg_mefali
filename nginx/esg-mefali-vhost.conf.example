# ==========================================
# Virtual host ESG Mefali pour reverse proxy existant
# ==========================================
# A ajouter dans le nginx UAfricas (ou tout autre
# reverse proxy central sur le VPS).
#
# Sur le serveur UAfricas :
#   - Copier ce fichier dans /opt/uafricas/nginx/
#     et l'inclure depuis nginx.conf via :
#       include /etc/nginx/conf.d/esg-mefali-vhost.conf;
#   - OU coller son contenu dans le bloc http{} du
#     nginx.conf UAfricas existant.
#
# Prerequis :
#   1. Containers ESG Mefali demarres via
#      docker-compose.prod.yml (expose frontend
#      sur 127.0.0.1:3010 et backend sur 127.0.0.1:8010)
#   2. Certificat Let's Encrypt obtenu pour
#      esg.mefali.com
#   3. Le container nginx UAfricas a acces au host
#      via "host.docker.internal" (Linux : ajouter
#      extra_hosts dans son docker-compose) ou via
#      "network_mode: host" pour le nginx.
# ==========================================

upstream esg_mefali_backend {
    server 127.0.0.1:8010;
    keepalive 32;
}

upstream esg_mefali_frontend {
    server 127.0.0.1:3010;
    keepalive 32;
}

# HTTP : redirection HTTPS
server {
    listen 80;
    server_name esg.mefali.com;

    # Let's Encrypt ACME challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS : ESG Mefali
server {
    listen 443 ssl;
    http2 on;
    server_name esg.mefali.com;

    # Certificats Let's Encrypt
    ssl_certificate /etc/nginx/ssl/esg-mefali/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/esg-mefali/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-RSA-AES256-GCM-SHA512:DHE-RSA-AES256-GCM-SHA512:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL_ESG:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # Security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    # Taille maximale des uploads (rapports PDF, documents ESG)
    client_max_body_size 50M;
    client_body_timeout 120s;

    # Compression
    gzip on;
    gzip_vary on;
    gzip_comp_level 6;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;

    # API Backend (FastAPI + LangGraph SSE)
    location /api/ {
        proxy_pass http://esg_mefali_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection '';

        # SSE streaming : desactiver tout buffering
        proxy_buffering off;
        proxy_cache off;
        proxy_request_buffering off;
        chunked_transfer_encoding on;

        # Timeouts longs pour generations LLM et rapports PDF
        proxy_read_timeout 600s;
        proxy_connect_timeout 75s;
        proxy_send_timeout 600s;
    }

    # Frontend Nuxt 4 (SSR Node)
    location / {
        proxy_pass http://esg_mefali_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_read_timeout 60s;
        proxy_connect_timeout 60s;
    }
}
