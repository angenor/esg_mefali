# ==========================================
# Virtual host ESG Mefali — a inserer dans le
# nginx.conf UAfricas (reverse proxy central)
# ==========================================
#
# Prerequis :
#   1. Containers ESG Mefali demarres et connectes
#      au reseau Docker uafricas_uafricas_net :
#        docker network inspect uafricas_uafricas_net \
#          | grep -E "esg_mefali_(backend|frontend)"
#   2. Certificat Let's Encrypt pour esg.mefali.com
#      copie dans /opt/uafricas/nginx/ssl/esg-mefali/
#      (fullchain.pem + privkey.pem)
#
# Les upstreams utilisent les noms DNS internes
# Docker — pas besoin d'exposer les ports host.
# ==========================================

upstream upstream_esg_mefali_backend {
    # Nom DNS Docker du container backend ESG Mefali
    # (reseau partage uafricas_uafricas_net)
    server esg_mefali_backend:8000;
    keepalive 32;
}

upstream upstream_esg_mefali_frontend {
    server esg_mefali_frontend:3000;
    keepalive 32;
}

# HTTP : ACME challenge + redirection HTTPS
server {
    listen 80;
    server_name esg.mefali.com;

    # Let's Encrypt ACME challenge (partage avec UAfricas)
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS : ESG Mefali
server {
    listen 443 ssl;
    http2 on;
    server_name esg.mefali.com;

    # Certificats Let's Encrypt (deposes par deploy.sh ssl)
    ssl_certificate /etc/nginx/ssl/esg-mefali/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/esg-mefali/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL_ESG:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # Security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    # Taille maximale des uploads (rapports PDF, documents ESG)
    client_max_body_size 50M;
    client_body_timeout 120s;

    # API Backend (FastAPI + LangGraph SSE)
    location /api/ {
        proxy_pass http://upstream_esg_mefali_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection '';

        # SSE streaming : desactiver tout buffering
        proxy_buffering off;
        proxy_cache off;
        proxy_request_buffering off;
        chunked_transfer_encoding on;

        # Timeouts longs pour generations LLM et rapports PDF
        proxy_read_timeout 600s;
        proxy_connect_timeout 75s;
        proxy_send_timeout 600s;
    }

    # Frontend Nuxt 4 (SSR Node)
    location / {
        proxy_pass http://upstream_esg_mefali_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_read_timeout 60s;
        proxy_connect_timeout 60s;
    }
}
