  "integration_points": [
    {
      "from": "frontend",
      "to": "backend",
      "type": "REST JSON",
      "protocol": "HTTPS",
      "description": "Appels synchrones via fetch() natif, header Authorization Bearer JWT, base URL via runtimeConfig.public.apiBase (env NUXT_PUBLIC_API_BASE)"
    },
    {
      "from": "frontend",
      "to": "backend",
      "type": "Server-Sent Events (SSE)",
      "protocol": "HTTPS + text/event-stream",
      "endpoint": "POST /api/chat/{conversation_id}/messages",
      "description": "Stream LangGraph : events token / done / document_* / profile_* / tool_call_* / interactive_question*",
      "implementation": "frontend/app/composables/useChat.ts ↔ backend/app/api/chat.py + backend/app/graph/"
    },
    {
      "from": "frontend",
      "to": "backend",
      "type": "Multipart upload",
      "protocol": "HTTPS multipart/form-data",
      "endpoints": [
        "POST /api/documents/",
        "POST /api/chat/{id}/messages (champ file optionnel)"
      ],
      "description": "Upload de documents (PDF/DOCX/XLSX/image) déclenche extraction + OCR + embeddings pgvector + analyse LLM"
    }
  ],
  "shared_conventions": {
    "identifiers": "UUID v4 string",
    "timestamps": "ISO 8601 UTC",
    "currency": "FCFA en entiers (pas de float)",
    "scores": "0-100 float",
    "emissions": "tCO2e float",
    "language_code": "Français pour UI et identifiants anglais pour code"
  }
